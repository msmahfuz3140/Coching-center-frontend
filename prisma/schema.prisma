// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum CourseCategory {
  DIPLOMA
  DUET_TECH
  DUET_NON_TECH
  SSC_9_10
  POLYTECHNIC_ADMISSION
  REFERRED_BATCH
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Auth Models (Better Auth) ───

model User {
  id            String      @id @default(cuid()) @map("_id")
  email         String      @unique
  username      String?
  name          String?
  emailVerified Boolean     @default(false)
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  role          Role        @default(STUDENT)
  phone         String?
  isBlocked     Boolean     @default(false)

  sessions      Session[]
  accounts      Account[]

  // LMS Relations
  enrollments   Enrollment[]
  createdCourses Course[]   @relation("CourseInstructor")
  notices       Notice[]
  notifications Notification[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid()) @map("_id")
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id           String    @id @default(cuid()) @map("_id")
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  value      String
  expiresAt  DateTime

  @@map("verification")
}

// ─── LMS Models ───

model Course {
  id            String         @id @default(cuid()) @map("_id")
  title         String
  slug          String         @unique
  description   String?
  thumbnail     String?
  price         Float          @default(0)
  isPublished   Boolean        @default(false)
  category      CourseCategory
  semester      Int?           // For Diploma (1-7)
  duration      String?        // e.g. "6 months", "1 year"
  requirements  String[]       // Prerequisites
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Instructor
  instructorId  String
  instructor    User           @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: Cascade)

  // Relations
  syllabus      Syllabus[]
  videos        Video[]
  enrollments   Enrollment[]
  notices       Notice[]
  notifications Notification[]

  @@map("course")
}

model Syllabus {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  description String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Topics under this syllabus item
  topics      Topic[]

  @@map("syllabus")
}

model Topic {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  description String?
  duration    String?  // e.g. "2 weeks", "3 classes"
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  syllabusId  String
  syllabus    Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)

  @@map("topic")
}

model Video {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  description String?
  youtubeUrl  String
  duration    Int?     // duration in seconds
  orderIndex  Int      @default(0)
  isFree      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("video")
}

model Enrollment {
  id              String           @id @default(cuid()) @map("_id")
  enrolledAt      DateTime         @default(now())
  completedAt     DateTime?
  progress        Float            @default(0) // 0.0 to 100.0

  // Enrollment request fields
  status          EnrollmentStatus @default(PENDING)
  requestMessage  String?          // Message from student when requesting
  responseMessage String?          // Message from admin when approving/rejecting
  reviewedBy      String?          // Admin who reviewed the request
  reviewedAt      DateTime?        // When the request was reviewed

  // Relations
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollment")
}

model Notice {
  id        String   @id @default(cuid()) @map("_id")
  title     String
  content   String
  image     String?
  priority  String   @default("normal") // low, normal, high, urgent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("notice")
}

model Notification {
  id        String   @id @default(cuid()) @map("_id")
  type      String   // "notice" | "video" | "enrollment_approved" | "enrollment_rejected"
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Recipient
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional links
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("notification")
}